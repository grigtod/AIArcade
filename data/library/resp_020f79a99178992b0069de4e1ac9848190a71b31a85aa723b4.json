  "title": "Rocket Cat: Grid Burn",
  "attractText": "ROCKET CAT: GRID BURN\n\nButton 1: start / place spark\nButton 2: dash\nStick: move one tile at a time\n\nLight every safe tile before the ember swarm traps you.",
  "html": "<!DOCTYPE html><html><head>\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<script>\nwindow.arcadeInput = {\n  up: false,\n  down: false,\n  left: false,\n  right: false,\n  upPressed: false,\n  downPressed: false,\n  leftPressed: false,\n  rightPressed: false,\n  button1: false,\n  button2: false,\n  button1Pressed: false,\n  button2Pressed: false,\n  start: false,\n  confirm: false,\n  action: false,\n  secondary: false,\n  startPressed: false,\n  confirmPressed: false,\n  actionPressed: false,\n  secondaryPressed: false\n};\n\nlet previousCompatInput = {\n  up: false,\n  down: false,\n  left: false,\n  right: false,\n  button1: false,\n  button2: false\n};\n\nfunction dispatchCompatKey(type, key, code) {\n  try {\n    const event = new KeyboardEvent(type, {\n      key,\n      code,\n      bubbles: true,\n      cancelable: true\n    });\n    window.dispatchEvent(event);\n    document.dispatchEvent(event);\n    document.body?.dispatchEvent(event);\n  } catch {}\n}\n\nfunction dispatchCompatPointerPress() {\n  try {\n    const x = Math.round(window.innerWidth / 2);\n    const y = Math.round(window.innerHeight / 2);\n    const target = document.elementFromPoint(x, y) || document.body || document.documentElement;\n    ['pointerdown', 'mousedown', 'pointerup', 'mouseup', 'click'].forEach((type) => {\n      const event = new MouseEvent(type, {\n        bubbles: true,\n        cancelable: true,\n        clientX: x,\n        clientY: y\n      });\n      target?.dispatchEvent(event);\n    });\n  } catch {}\n}\n\nfunction withArcadeAliases(source) {\n  const state = source || {};\n  return {\n    ...state,\n    start: Boolean(state.button1),\n    confirm: Boolean(state.button1),\n    action: Boolean(state.button1),\n    secondary: Boolean(state.button2),\n    startPressed: Boolean(state.button1Pressed),\n    confirmPressed: Boolean(state.button1Pressed),\n    actionPressed: Boolean(state.button1Pressed),\n    secondaryPressed: Boolean(state.button2Pressed)\n  };\n}\n\nfunction applyCompatInput(nextState) {\n  const mappings = [\n    ['up', 'ArrowUp', 'ArrowUp'],\n    ['down', 'ArrowDown', 'ArrowDown'],\n    ['left', 'ArrowLeft', 'ArrowLeft'],\n    ['right', 'ArrowRight', 'ArrowRight'],\n    ['button1', 'Enter', 'Enter'],\n    ['button2', 'Shift', 'ShiftLeft']\n  ];\n\n  for (const [field, key, code] of mappings) {\n    const wasDown = Boolean(previousCompatInput[field]);\n    const isDown = Boolean(nextState[field]);\n    if (isDown && !wasDown) {\n      dispatchCompatKey('keydown', key, code);\n    }\n    if (!isDown && wasDown) {\n      dispatchCompatKey('keyup', key, code);\n    }\n  }\n\n  if (nextState.button1Pressed) {\n    dispatchCompatKey('keydown', ' ', 'Space');\n    dispatchCompatKey('keyup', ' ', 'Space');\n    dispatchCompatPointerPress();\n  }\n\n  previousCompatInput = {\n    up: Boolean(nextState.up),\n    down: Boolean(nextState.down),\n    left: Boolean(nextState.left),\n    right: Boolean(nextState.right),\n    button1: Boolean(nextState.button1),\n    button2: Boolean(nextState.button2)\n  };\n}\n\nwindow.addEventListener('message', (event) => {\n  if (!event.data || typeof event.data !== 'object') {\n    return;\n  }\n\n  if (event.data.type === 'arcade-input') {\n    const nextState = withArcadeAliases(event.data.state);\n    applyCompatInput(nextState);\n    window.arcadeInput = nextState;\n    return;\n  }\n\n  if (event.data.type === 'arcade-capture-thumbnail') {\n    captureArcadeThumbnail();\n  }\n});\n\nfunction postHostMessage(type, extra) {\n  try {\n    window.parent.postMessage({ type, ...extra }, '*');\n  } catch {}\n}\n\nfunction showArcadeFailure(message) {\n  let overlay = document.getElementById('arcade-host-failure');\n  if (!overlay) {\n    overlay = document.createElement('div');\n    overlay.id = 'arcade-host-failure';\n    overlay.style.position = 'fixed';\n    overlay.style.inset = '0';\n    overlay.style.zIndex = '999999';\n    overlay.style.display = 'grid';\n    overlay.style.placeItems = 'center';\n    overlay.style.padding = '24px';\n    overlay.style.background = 'rgba(2, 5, 11, 0.92)';\n    overlay.style.color = '#f2f4e8';\n    overlay.style.fontFamily = 'Trebuchet MS, Segoe UI, sans-serif';\n    overlay.style.textAlign = 'center';\n    overlay.innerHTML =\n      '<div style=\"max-width:36rem;border:1px solid rgba(89,255,216,0.35);border-radius:24px;padding:22px;background:rgba(6,15,27,0.92)\">' +\n      '<div style=\"color:#59ffd8;letter-spacing:0.16em;text-transform:uppercase;font-size:12px;margin-bottom:12px\">Generated Game Error</div>' +\n      '<div id=\"arcade-host-failure-text\" style=\"font-size:18px;line-height:1.5;white-space:pre-wrap\"></div>' +\n      '</div>';\n    document.body.appendChild(overlay);\n  }\n\n  const text = overlay.querySelector('#arcade-host-failure-text');\n  if (text) {\n    text.textContent = message;\n  }\n}\n\nfunction wrapThumbnailText(context, text, maxWidth) {\n  const words = String(text || 'Arcade Game').split(/\\s+/).filter(Boolean);\n  const lines = [];\n  let currentLine = '';\n\n  for (const word of words) {\n    const nextLine = currentLine ? currentLine + ' ' + word : word;\n    if (context.measureText(nextLine).width > maxWidth && currentLine) {\n      lines.push(currentLine);\n      currentLine = word;\n      continue;\n    }\n\n    currentLine = nextLine;\n  }\n\n  if (currentLine) {\n    lines.push(currentLine);\n  }\n\n  return lines.slice(0, 3);\n}\n\nfunction captureArcadeThumbnail() {\n  try {\n    const output = document.createElement('canvas');\n    output.width = 320;\n    output.height = 320;\n    const context = output.getContext('2d');\n    if (!context) {\n      return;\n    }\n\n    context.fillStyle = '#09111a';\n    context.fillRect(0, 0, output.width, output.height);\n\n    const sourceCanvas = document.querySelector('canvas');\n    if (sourceCanvas && sourceCanvas.width > 0 && sourceCanvas.height > 0) {\n      const sourceSize = Math.min(sourceCanvas.width, sourceCanvas.height);\n      const sx = Math.max(0, (sourceCanvas.width - sourceSize) / 2);\n      const sy = Math.max(0, (sourceCanvas.height - sourceSize) / 2);\n      context.imageSmoothingEnabled = false;\n      context.drawImage(sourceCanvas, sx, sy, sourceSize, sourceSize, 0, 0, output.width, output.height);\n    } else {\n      const title =\n        document.title ||\n        document.querySelector('h1, h2, [data-title]')?.textContent ||\n        'Arcade Game';\n\n      context.fillStyle = '#11263a';\n      context.fillRect(18, 18, 284, 284);\n      context.strokeStyle = 'rgba(126, 225, 208, 0.45)';\n      context.lineWidth = 2;\n      context.strokeRect(18, 18, 284, 284);\n      context.fillStyle = '#f2f4e8';\n      context.font = 'bold 26px Trebuchet MS, Segoe UI, sans-serif';\n      const lines = wrapThumbnailText(context, title, 220);\n      lines.forEach((line, index) => {\n        context.fillText(line, 34, 126 + index * 34);\n      });\n    }\n\n    postHostMessage('arcade-thumbnail', {\n      imageDataUrl: output.toDataURL('image/png'),\n    });\n  } catch {}\n}\n\nwindow.addEventListener('DOMContentLoaded', () => {\n  try {\n    document.body?.setAttribute('tabindex', '-1');\n    document.body?.focus?.();\n    window.focus?.();\n  } catch {}\n  postHostMessage('arcade-game-dom-ready', {});\n});\n\nwindow.addEventListener('error', (event) => {\n  const message = event?.error?.stack || event?.message || 'Unknown game error.';\n  showArcadeFailure(message);\n  postHostMessage('arcade-game-error', { message });\n});\n\nwindow.addEventListener('unhandledrejection', (event) => {\n  const reason = event?.reason;\n  const message =\n    (reason && typeof reason === 'object' && reason.stack) ||\n    (reason && typeof reason === 'object' && reason.message) ||\n    String(reason || 'Unhandled promise rejection in generated game.');\n  showArcadeFailure(message);\n  postHostMessage('arcade-game-error', { message });\n});\n</script>\n<meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>html,body{margin:0;background:#0b0f1a;height:100%;overflow:hidden}body{display:flex;align-items:center;justify-content:center}canvas{width:min(96vmin,960px);height:min(96vmin,960px);image-rendering:auto;background:#111827;box-shadow:0 0 40px #000}*{box-sizing:border-box}</style></head><body><canvas id=\"c\" width=\"960\" height=\"960\"></canvas><script>(()=>{const canvas=document.getElementById('c'),ctx=canvas.getContext('2d');const W=960,H=960;let state='title',t=0,last=0;const input=()=>window.arcadeInput||{};let audioCtx=null,audioOn=false;function unlockAudio(){if(audioOn)return;try{audioCtx=new (window.AudioContext||window.webkitAudioContext)();audioOn=true;}catch(e){}}function beep(f,d,tv,v){if(!audioOn||!audioCtx)return;const n=audioCtx.currentTime,o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type=tv||'square';o.frequency.setValueAtTime(f,n);g.gain.setValueAtTime(v||0.04,n);g.gain.exponentialRampToValueAtTime(0.0001,n+d);o.connect(g);g.connect(audioCtx.destination);o.start(n);o.stop(n+d);}const grid={cols:9,rows:9,size:84,ox:102,oy:140};let board,player,enemies,sparks,score,bestChain,movesLeft,dashCooldown,spawnTimer,winTimer,deadTimer;function resetGame(){board=[];for(let y=0;y<grid.rows;y++){let row=[];for(let x=0;x<grid.cols;x++)row.push(0);board.push(row);}player={x:4,y:4,px:4,py:4,flash:0};board[4][4]=1;enemies=[];sparks=[];score=0;bestChain=0;movesLeft=999;dashCooldown=0;spawnTimer=0;winTimer=0;deadTimer=0;spawnEnemy();spawnEnemy();state='play';t=0;}function occupied(x,y){for(let i=0;i<enemies.length;i++)if(enemies[i].x===x&&enemies[i].y===y)return true;return false;}function spawnEnemy(){let tries=0;while(tries++<200){let edge=Math.floor(Math.random()*4),x=0,y=0;if(edge===0){x=Math.floor(Math.random()*grid.cols);y=0;}if(edge===1){x=grid.cols-1;y=Math.floor(Math.random()*grid.rows);}if(edge===2){x=Math.floor(Math.random()*grid.cols);y=grid.rows-1;}if(edge===3){x=0;y=Math.floor(Math.random()*grid.rows);}if((x!==player.x||y!==player.y)&&!occupied(x,y)){enemies.push({x:x,y:y,step:0,glow:0});return;}}}function countLit(){let n=0;for(let y=0;y<grid.rows;y++)for(let x=0;x<grid.cols;x++)if(board[y][x]===1)n++;return n;}function tryMove(dx,dy){let nx=player.x+dx,ny=player.y+dy;if(nx<0||ny<0||nx>=grid.cols||ny>=grid.rows)return;if(occupied(nx,ny)){hitPlayer();return;}player.px=player.x;player.py=player.y;player.x=nx;player.y=ny;player.flash=1;let chain=1;if(board[ny][nx]===0){board[ny][nx]=1;score+=10;beep(720,0.08,'square',0.05);}else{score+=1;beep(420,0.05,'triangle',0.03);}const dirs=[[1,0],[-1,0],[0,1],[0,-1]];for(let i=0;i<dirs.length;i++){const d=dirs[i],sx=nx+d[0],sy=ny+d[1];if(sx>=0&&sy>=0&&sx<grid.cols&&sy<grid.rows&&board[sy][sx]===0){sparks.push({x:sx,y:sy,life:0.35});board[sy][sx]=1;chain++;}}if(chain>1){score+=chain*12;bestChain=Math.max(bestChain,chain);beep(900,0.12,'sawtooth',0.05);}enemyTurn();if(countLit()===grid.cols*grid.rows){state='win';winTimer=1.2;beep(520,0.14,'triangle',0.06);setTimeout(()=>beep(780,0.18,'triangle',0.05),70);}}function dash(){if(dashCooldown>0)return;const i=input();let dx=0,dy=0;if(i.left)dx=-1;else if(i.right)dx=1;else if(i.up)dy=-1;else if(i.down)dy=1;else return;let nx=player.x+dx*2,ny=player.y+dy*2;if(nx<0||ny<0||nx>=grid.cols||ny>=grid.rows)return;if(occupied(player.x+dx,player.y+dy)||occupied(nx,ny))return;player.px=player.x;player.py=player.y;player.x=nx;player.y=ny;player.flash=1.4;dashCooldown=2;let gained=0;for(let s=0;s<3;s++){let tx=player.x-dx*s,ty=player.y-dy*s;if(tx>=0&&ty>=0&&tx<grid.cols&&ty<grid.rows&&board[ty][tx]===0){board[ty][tx]=1;gained++;sparks.push({x:tx,y:ty,life:0.45});}}score+=8+gained*8;beep(260,0.06,'sawtooth',0.05);setTimeout(()=>beep(180,0.07,'square',0.04),40);enemyTurn();if(countLit()===grid.cols*grid.rows){state='win';winTimer=1.2;}}function hitPlayer(){if(state!=='play')return;state='dead';deadTimer=1.4;beep(120,0.2,'sawtooth',0.07);setTimeout(()=>beep(80,0.25,'square',0.05),60);}function enemyTurn(){for(let k=0;k<enemies.length;k++){let e=enemies[k];let best={d:999,x:e.x,y:e.y};const opts=[[0,0],[1,0],[-1,0],[0,1],[0,-1]];for(let i=0;i<opts.length;i++){let nx=e.x+opts[i][0],ny=e.y+opts[i][1];if(nx<0||ny<0||nx>=grid.cols||ny>=grid.rows)continue;let blocked=false;for(let j=0;j<enemies.length;j++)if(j!==k&&enemies[j].x===nx&&enemies[j].y===ny)blocked=true;if(blocked)continue;let d=Math.abs(nx-player.x)+Math.abs(ny-player.y);if(d<best.d||(d===best.d&&Math.random()<0.25))best={d:d,x:nx,y:ny};}e.x=best.x;e.y=best.y;e.glow=1;if(e.x===player.x&&e.y===player.y){hitPlayer();return;}}spawnTimer++;if(spawnTimer>=4){spawnTimer=0;if(enemies.length<8)spawnEnemy();}if(dashCooldown>0)dashCooldown--;}function update(dt){t+=dt;const i=input();if((i.button1Pressed||i.button2Pressed)&&!audioOn)unlockAudio();if(state==='title'){if(i.button1Pressed){unlockAudio();beep(660,0.08,'triangle',0.05);resetGame();}return;}if(state==='play'){if(i.button1Pressed){beep(500,0.04,'triangle',0.03);}if(i.leftPressed)tryMove(-1,0); else if(i.rightPressed)tryMove(1,0); else if(i.upPressed)tryMove(0,-1); else if(i.downPressed)tryMove(0,1); if(i.button2Pressed)dash(); for(let n=sparks.length-1;n>=0;n--){sparks[n].life-=dt;if(sparks[n].life<=0)sparks.splice(n,1);} player.flash=Math.max(0,player.flash-dt*2.2); for(let n=0;n<enemies.length;n++)enemies[n].glow=Math.max(0,enemies[n].glow-dt*2); } else if(state==='dead'){deadTimer-=dt;if(i.button1Pressed&&deadTimer<1.1){beep(660,0.08,'triangle',0.05);resetGame();}} else if(state==='win'){winTimer-=dt;if(i.button1Pressed&&winTimer<1.1){beep(760,0.08,'triangle',0.05);resetGame();}}}function rr(x,y,w,h,r,c){ctx.fillStyle=c;ctx.beginPath();ctx.moveTo(x+r,y);ctx.arcTo(x+w,y,x+w,y+h,r);ctx.arcTo(x+w,y+h,x,y+h,r);ctx.arcTo(x,y+h,x,y,r);ctx.arcTo(x,y,x+w,y,r);ctx.fill();}function draw(){ctx.clearRect(0,0,W,H);let bg=ctx.createLinearGradient(0,0,0,H);bg.addColorStop(0,'#09111f');bg.addColorStop(1,'#170f24');ctx.fillStyle=bg;ctx.fillRect(0,0,W,H);for(let s=0;s<70;s++){let x=(s*137%W),y=(s*83%H),a=0.15+0.1*Math.sin(t*0.8+s);ctx.fillStyle='rgba(255,255,255,'+a+')';ctx.fillRect(x,y,2,2);} ctx.fillStyle='#1a2238';rr(80,110,800,760,28,'#10182b'); if(state==='title'){ctx.textAlign='center';ctx.fillStyle='#ffd54a';ctx.font='bold 88px sans-serif';ctx.fillText('ROCKET CAT',480,240);ctx.fillStyle='#8be9ff';ctx.font='bold 72px sans-serif';ctx.fillText('GRID BURN',480,320); rr(165,390,630,210,24,'#16233f'); ctx.fillStyle='#fff';ctx.font='bold 34px sans-serif';ctx.fillText('Light every tile before the ember swarm closes in.',480,455);ctx.font='28px sans-serif';ctx.fillStyle='#d2dcff';ctx.fillText('Stick: move one tile per tap',480,505);ctx.fillText('Button 2: dash two tiles',480,545);ctx.fillStyle='#ffcf56';ctx.font='bold 42px sans-serif';ctx.fillText('PRESS BUTTON 1',480,670+Math.sin(t*5)*8); ctx.fillStyle='#9db0d8';ctx.font='24px sans-serif';ctx.fillText('Plan routes. Dodge slowly. Paint the board bright.',480,735); return;} ctx.strokeStyle='#31456e';ctx.lineWidth=4; for(let y=0;y<grid.rows;y++)for(let x=0;x<grid.cols;x++){let gx=grid.ox+x*grid.size,gy=grid.oy+y*grid.size;let lit=board[y][x]===1;rr(gx+4,gy+4,grid.size-8,grid.size-8,16,lit?'#ffd34d':'#1e2a44'); if(lit){ctx.fillStyle='rgba(255,255,255,0.14)';rr(gx+12,gy+12,grid.size-24,18,9,'rgba(255,255,255,0.14)');}} for(let i=0;i<sparks.length;i++){let s=sparks[i],gx=grid.ox+s.x*grid.size+grid.size/2,gy=grid.oy+s.y*grid.size+grid.size/2,r=20*(s.life/0.45);ctx.fillStyle='rgba(255,245,180,'+(s.life*2)+')';ctx.beginPath();ctx.arc(gx,gy,r,0,Math.PI*2);ctx.fill();} for(let i=0;i<enemies.length;i++){let e=enemies[i],gx=grid.ox+e.x*grid.size+grid.size/2,gy=grid.oy+e.y*grid.size+grid.size/2;ctx.fillStyle='rgba(255,90,90,'+(0.2+e.glow*0.4)+')';ctx.beginPath();ctx.arc(gx,gy,32+e.glow*10,0,Math.PI*2);ctx.fill();ctx.fillStyle='#ff5d5d';ctx.beginPath();ctx.arc(gx,gy,25,0,Math.PI*2);ctx.fill();ctx.fillStyle='#2a0d0d';ctx.beginPath();ctx.arc(gx-8,gy-4,4,0,Math.PI*2);ctx.arc(gx+8,gy-4,4,0,Math.PI*2);ctx.fill();} let px=grid.ox+player.x*grid.size+grid.size/2,py=grid.oy+player.y*grid.size+grid.size/2; ctx.fillStyle='rgba(139,233,255,'+(0.2+player.flash*0.2)+')';ctx.beginPath();ctx.arc(px,py,34+player.flash*10,0,Math.PI*2);ctx.fill(); ctx.fillStyle='#8be9ff';ctx.beginPath();ctx.arc(px,py,24,0,Math.PI*2);ctx.fill(); ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(px-8,py-5,5,0,Math.PI*2);ctx.arc(px+8,py-5,5,0,Math.PI*2);ctx.fill(); ctx.fillStyle='#203040';ctx.fillRect(px-12,py+7,24,4); ctx.fillStyle='#ff8ab3';ctx.beginPath();ctx.moveTo(px,py+1);ctx.lineTo(px-5,py+7);ctx.lineTo(px+5,py+7);ctx.fill(); ctx.fillStyle='#d7e4ff';ctx.font='bold 30px sans-serif';ctx.textAlign='left';ctx.fillText('LIT '+countLit()+'/81',110,85);ctx.fillText('SCORE '+score,360,85);ctx.fillText('DASH '+(dashCooldown>0?'CHARGING':'READY'),640,85); if(state==='dead'){ctx.fillStyle='rgba(10,0,0,0.55)';ctx.fillRect(0,0,W,H);ctx.textAlign='center';ctx.fillStyle='#ff6a6a';ctx.font='bold 92px sans-serif';ctx.fillText('TRAPPED!',480,410);ctx.fillStyle='#fff';ctx.font='36px sans-serif';ctx.fillText('Score '+score,480,485);ctx.fillText('Press Button 1 to retry',480,555);} if(state==='win'){ctx.fillStyle='rgba(255,220,80,0.16)';ctx.fillRect(0,0,W,H);ctx.textAlign='center';ctx.fillStyle='#ffe16b';ctx.font='bold 92px sans-serif';ctx.fillText('ALL LIT!',480,410);ctx.fillStyle='#fff';ctx.font='36px sans-serif';ctx.fillText('Final Score '+score,480,485);ctx.fillText('Press Button 1 to play again',480,555);}} function loop(ts){let dt=Math.min(0.033,(ts-last||16)/1000);last=ts;update(dt);draw();requestAnimationFrame(loop);} draw();requestAnimationFrame(loop);})();</script></body></html>",
