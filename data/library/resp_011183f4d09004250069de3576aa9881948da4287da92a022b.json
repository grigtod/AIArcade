  "title": "SCRAP GOLEM: LASER MAZE",
  "attractText": "SCRAP GOLEM: LASER MAZE — A heavy metal brute crawls through a thinking-person's bullet grid. Move with the stick. BUTTON 1: start / fire. BUTTON 2: bulldoze dash. Survive waves, break turrets, build combo, reach the core.",
  "html": "<!DOCTYPE html><html><head>\n\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<script>\nwindow.arcadeInput = {\n  up: false,\n  down: false,\n  left: false,\n  right: false,\n  upPressed: false,\n  downPressed: false,\n  leftPressed: false,\n  rightPressed: false,\n  button1: false,\n  button2: false,\n  button1Pressed: false,\n  button2Pressed: false\n};\n\nwindow.addEventListener('message', (event) => {\n  if (!event.data || typeof event.data !== 'object') {\n    return;\n  }\n\n  if (event.data.type === 'arcade-input') {\n    window.arcadeInput = event.data.state;\n    return;\n  }\n\n  if (event.data.type === 'arcade-capture-thumbnail') {\n    captureArcadeThumbnail();\n  }\n});\n\nfunction postHostMessage(type, extra) {\n  try {\n    window.parent.postMessage({ type, ...extra }, '*');\n  } catch {}\n}\n\nfunction showArcadeFailure(message) {\n  let overlay = document.getElementById('arcade-host-failure');\n  if (!overlay) {\n    overlay = document.createElement('div');\n    overlay.id = 'arcade-host-failure';\n    overlay.style.position = 'fixed';\n    overlay.style.inset = '0';\n    overlay.style.zIndex = '999999';\n    overlay.style.display = 'grid';\n    overlay.style.placeItems = 'center';\n    overlay.style.padding = '24px';\n    overlay.style.background = 'rgba(2, 5, 11, 0.92)';\n    overlay.style.color = '#f2f4e8';\n    overlay.style.fontFamily = 'Trebuchet MS, Segoe UI, sans-serif';\n    overlay.style.textAlign = 'center';\n    overlay.innerHTML =\n      '<div style=\"max-width:36rem;border:1px solid rgba(89,255,216,0.35);border-radius:24px;padding:22px;background:rgba(6,15,27,0.92)\">' +\n      '<div style=\"color:#59ffd8;letter-spacing:0.16em;text-transform:uppercase;font-size:12px;margin-bottom:12px\">Generated Game Error</div>' +\n      '<div id=\"arcade-host-failure-text\" style=\"font-size:18px;line-height:1.5;white-space:pre-wrap\"></div>' +\n      '</div>';\n    document.body.appendChild(overlay);\n  }\n\n  const text = overlay.querySelector('#arcade-host-failure-text');\n  if (text) {\n    text.textContent = message;\n  }\n}\n\nfunction wrapThumbnailText(context, text, maxWidth) {\n  const words = String(text || 'Arcade Game').split(/\\s+/).filter(Boolean);\n  const lines = [];\n  let currentLine = '';\n\n  for (const word of words) {\n    const nextLine = currentLine ? currentLine + ' ' + word : word;\n    if (context.measureText(nextLine).width > maxWidth && currentLine) {\n      lines.push(currentLine);\n      currentLine = word;\n      continue;\n    }\n\n    currentLine = nextLine;\n  }\n\n  if (currentLine) {\n    lines.push(currentLine);\n  }\n\n  return lines.slice(0, 3);\n}\n\nfunction captureArcadeThumbnail() {\n  try {\n    const output = document.createElement('canvas');\n    output.width = 320;\n    output.height = 320;\n    const context = output.getContext('2d');\n    if (!context) {\n      return;\n    }\n\n    context.fillStyle = '#09111a';\n    context.fillRect(0, 0, output.width, output.height);\n\n    const sourceCanvas = document.querySelector('canvas');\n    if (sourceCanvas && sourceCanvas.width > 0 && sourceCanvas.height > 0) {\n      const sourceSize = Math.min(sourceCanvas.width, sourceCanvas.height);\n      const sx = Math.max(0, (sourceCanvas.width - sourceSize) / 2);\n      const sy = Math.max(0, (sourceCanvas.height - sourceSize) / 2);\n      context.imageSmoothingEnabled = false;\n      context.drawImage(sourceCanvas, sx, sy, sourceSize, sourceSize, 0, 0, output.width, output.height);\n    } else {\n      const title =\n        document.title ||\n        document.querySelector('h1, h2, [data-title]')?.textContent ||\n        'Arcade Game';\n\n      context.fillStyle = '#11263a';\n      context.fillRect(18, 18, 284, 284);\n      context.strokeStyle = 'rgba(126, 225, 208, 0.45)';\n      context.lineWidth = 2;\n      context.strokeRect(18, 18, 284, 284);\n      context.fillStyle = '#f2f4e8';\n      context.font = 'bold 26px Trebuchet MS, Segoe UI, sans-serif';\n      const lines = wrapThumbnailText(context, title, 220);\n      lines.forEach((line, index) => {\n        context.fillText(line, 34, 126 + index * 34);\n      });\n    }\n\n    postHostMessage('arcade-thumbnail', {\n      imageDataUrl: output.toDataURL('image/png'),\n    });\n  } catch {}\n}\n\nwindow.addEventListener('DOMContentLoaded', () => {\n  postHostMessage('arcade-game-dom-ready', {});\n});\n\nwindow.addEventListener('error', (event) => {\n  const message = event?.error?.stack || event?.message || 'Unknown game error.';\n  showArcadeFailure(message);\n  postHostMessage('arcade-game-error', { message });\n});\n\nwindow.addEventListener('unhandledrejection', (event) => {\n  const reason = event?.reason;\n  const message =\n    (reason && typeof reason === 'object' && reason.stack) ||\n    (reason && typeof reason === 'object' && reason.message) ||\n    String(reason || 'Unhandled promise rejection in generated game.');\n  showArcadeFailure(message);\n  postHostMessage('arcade-game-error', { message });\n});\n</script>\n<meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no'><style>html,body{margin:0;background:#0a0f14;color:#d7e3ea;font-family:system-ui,sans-serif;height:100%;overflow:hidden}body{display:flex;align-items:center;justify-content:center}canvas{width:min(100vmin,960px);height:min(100vmin,960px);image-rendering:auto;background:#0b1118;box-shadow:0 0 30px #000 inset,0 0 40px #000} </style></head><body><canvas id='c' width='960' height='960'></canvas><script>(function(){const c=document.getElementById('c'),x=c.getContext('2d');const W=960,H=960;window.arcadeInput=window.arcadeInput||{};const A=window.arcadeInput;let audioCtx=null;function audioOn(){if(audioCtx)return;try{audioCtx=new (window.AudioContext||window.webkitAudioContext)()}catch(e){}}function beep(f=440,d=0.08,t='square',v=0.03,slide=0){if(!audioCtx)return;const o=audioCtx.createOscillator(),g=audioCtx.createGain();o.type=t;o.frequency.value=f;g.gain.value=v;o.connect(g);g.connect(audioCtx.destination);const n=audioCtx.currentTime;o.frequency.linearRampToValueAtTime(f+slide,n+d);g.gain.setValueAtTime(v,n);g.gain.exponentialRampToValueAtTime(0.0001,n+d);o.start(n);o.stop(n+d)}const lanes=[180,300,420,540,660,780];let state='title',t=0,score=0,best=0,wave=1,combo=0,comboTimer=0,spawnTimer=0,phase=0,flash=0,msgTimer=0;const player={lane:2,y:790,x:lanes[2],hp:5,heat:0,fireCd:0,dashCd:0,dash:0,dir:0};let bullets=[],enemies=[],hazards=[],particles=[],core=null;function reset(){score=0;wave=1;combo=0;comboTimer=0;spawnTimer=50;phase=0;flash=0;msgTimer=120;player.lane=2;player.x=lanes[2];player.hp=5;player.heat=0;player.fireCd=0;player.dashCd=0;player.dash=0;player.dir=0;bullets=[];enemies=[];hazards=[];particles=[];core=null;state='play'}function addP(x0,y0,n,col,s=1){for(let i=0;i<n;i++)particles.push({x:x0,y:y0,vx:(Math.random()*2-1)*5*s,vy:(Math.random()*2-1)*5*s,r:2+Math.random()*6,a:1,c:col})}function shoot(){if(player.fireCd>0)return;player.fireCd=18;bullets.push({x:player.x,y:player.y-38,vy:-11,r:8,p:true});beep(320,0.06,'square',0.04,120);player.heat=Math.min(1,player.heat+0.16)}function dash(){if(player.dashCd>0||player.dash>0)return;player.dash=14;player.dashCd=90;beep(120,0.12,'sawtooth',0.05,220);addP(player.x,player.y,14,'#8ff',1.5)}function hitPlayer(){if(player.dash>0||flash>0)return;player.hp--;flash=22;combo=0;comboTimer=0;beep(90,0.2,'sawtooth',0.07,-40);addP(player.x,player.y,20,'#f66',2);if(player.hp<=0){state='dead';best=Math.max(best,score);msgTimer=0;beep(60,0.5,'triangle',0.07,-50)}}function killEnemy(e,big){score+=10+combo*2;combo=Math.min(99,combo+1);comboTimer=180;addP(e.x,e.y,big?24:12,big?'#ffb84d':'#ffd966',big?2.2:1.3);beep(big?180:220,0.08,big?'sawtooth':'square',0.05,80)}function spawnWave(){let kind=Math.random();if(wave%5===0&&!core){core={hp:20+wave*2,y:120,phase:0};msgTimer=120;beep(150,0.2,'triangle',0.05,140);return}if(kind<0.45){let lane=(Math.random()*lanes.length)|0;enemies.push({type:'turret',lane,x:lanes[lane],y:-40,hp:3+((wave/3)|0),cd:80- Math.min(40,wave*2)})}else if(kind<0.75){let lane=(Math.random()*lanes.length)|0;hazards.push({type:'beam',lane,x:lanes[lane],y:-120,h:140,vy:3+wave*0.15,warn:50})}else{let lane=(Math.random()*(lanes.length-1))|0;enemies.push({type:'crawler',lane,x:lanes[lane],y:-40,hp:2+((wave/4)|0),vy:2.1+wave*0.12,dir:Math.random()<0.5?-1:1,step:40+((Math.random()*40)|0)})}}function update(){t++; if(A.button1Pressed||A.button2Pressed)audioOn(); if(state==='title'){if(A.button1Pressed){beep(500,0.08,'square',0.05,160);reset()}return} if(state==='dead' || state==='win'){msgTimer++; if(A.button1Pressed){beep(420,0.08,'square',0.05,120);reset()} return} if(A.leftPressed){player.lane=Math.max(0,player.lane-1);player.dir=-1;beep(180,0.03,'triangle',0.02,-20)} if(A.rightPressed){player.lane=Math.min(lanes.length-1,player.lane+1);player.dir=1;beep(180,0.03,'triangle',0.02,20)} if(A.upPressed){player.lane=Math.max(0,player.lane-1);player.dir=-1;beep(180,0.03,'triangle',0.02,-20)} if(A.downPressed){player.lane=Math.min(lanes.length-1,player.lane+1);player.dir=1;beep(180,0.03,'triangle',0.02,20)} player.x += (lanes[player.lane]-player.x)*0.35; if(A.button1)shoot(); if(A.button2Pressed)dash(); if(player.fireCd>0)player.fireCd--; if(player.dashCd>0)player.dashCd--; if(player.dash>0)player.dash--; player.heat=Math.max(0,player.heat-0.01); if(comboTimer>0)comboTimer--; else combo=0; if(flash>0)flash--; spawnTimer--; if(spawnTimer<=0){spawnWave(); spawnTimer=Math.max(28,86-wave*2)} if(!core&&enemies.length===0&&hazards.length===0&&wave<16&&spawnTimer<40&&Math.random()<0.02){wave++; msgTimer=60} if(core){core.phase++; if(t%36===0){for(let i=0;i<lanes.length;i++)if(Math.random()<0.7)hazards.push({type:'beam',lane:i,x:lanes[i],y:180,h:560,vy:0,warn:35,hold:40})} if(t%55===0){for(let i=0;i<2+wave/5;i++){let lane=(Math.random()*lanes.length)|0;enemies.push({type:'turret',lane,x:lanes[lane],y:-40,hp:3+((wave/3)|0),cd:50})}}} for(let i=bullets.length-1;i>=0;i--){let b=bullets[i];b.y+=b.vy;if(b.y<-30)bullets.splice(i,1)} for(let i=enemies.length-1;i>=0;i--){let e=enemies[i]; if(e.type==='turret'){e.y+=3; e.cd--; if(e.cd<=0&&e.y>80){hazards.push({type:'shot',x:e.x,y:e.y+20,vy:6+rnd(wave*0.12),r:10}); e.cd=80-Math.min(45,wave*2); beep(700,0.03,'square',0.015,-200)} } else { e.y+=e.vy; e.step--; if(e.step<=0){e.lane=Math.max(0,Math.min(lanes.length-1,e.lane+e.dir)); if(e.lane===0||e.lane===lanes.length-1)e.dir*=-1; e.step=45; } e.x+=(lanes[e.lane]-e.x)*0.25; } if(e.y>920){enemies.splice(i,1);continue} for(let j=bullets.length-1;j>=0;j--){let b=bullets[j],dx=b.x-e.x,dy=b.y-e.y;if(dx*dx+dy*dy<900){bullets.splice(j,1);e.hp--; if(e.hp<=0){killEnemy(e,e.type==='turret'); enemies.splice(i,1); break}else beep(240,0.03,'square',0.03,-40)}} if(i<enemies.length){let dx=player.x-e.x,dy=player.y-e.y;if(Math.abs(dx)<34&&Math.abs(dy)<34){if(player.dash>0){killEnemy(e,true);enemies.splice(i,1);score+=15}else hitPlayer()}}} for(let i=hazards.length-1;i>=0;i--){let h=hazards[i]; if(h.type==='beam'){if(h.warn>0)h.warn--; else if(h.hold>0)h.hold--; else h.y+=h.vy; if(h.y>1050){hazards.splice(i,1);continue} let active=h.warn<=0; if(active&&Math.abs(player.x-h.x)<28&&player.y>h.y&&player.y<h.y+h.h){if(player.dash<=0)hitPlayer()} } else { h.y+=h.vy; if(h.y>1000){hazards.splice(i,1);continue} let dx=player.x-h.x,dy=player.y-h.y;if(dx*dx+dy*dy<420){if(player.dash>0){hazards.splice(i,1);score+=3;beep(260,0.04,'square',0.03,60)}else{hazards.splice(i,1);hitPlayer()}} } } if(core){for(let j=bullets.length-1;j>=0;j--){let b=bullets[j],dx=b.x-480,dy=b.y-120;if(dx*dx+dy*dy<120*120){bullets.splice(j,1);core.hp--;beep(210,0.04,'square',0.04,40);addP(b.x,b.y,6,'#fff',0.8);if(core.hp<=0){state='win';best=Math.max(best,score+500);score+=500;beep(520,0.4,'triangle',0.07,300);addP(480,120,80,'#8ff',3);core=null;break}}} if(core&&Math.abs(player.x-480)<110&&player.y<210)hitPlayer()} for(let i=particles.length-1;i>=0;i--){let p=particles[i];p.x+=p.vx;p.y+=p.vy;p.vx*=0.96;p.vy*=0.96;p.a-=0.03;p.r*=0.99;if(p.a<=0)particles.splice(i,1)} } function rnd(n){return Math.random()*n} function draw(){x.fillStyle='#0b1118';x.fillRect(0,0,W,H); for(let i=0;i<6;i++){x.strokeStyle='rgba(120,180,220,0.16)';x.lineWidth=4;x.beginPath();x.moveTo(lanes[i],90);x.lineTo(lanes[i],860);x.stroke()} x.strokeStyle='#1f3846';x.lineWidth=6;x.strokeRect(90,90,780,780); x.fillStyle='#11202a';x.fillRect(90,820,780,50); if(state==='title'){let g=x.createLinearGradient(0,0,0,H);g.addColorStop(0,'#8ff');g.addColorStop(1,'#4af');x.fillStyle=g;x.font='bold 84px system-ui';x.textAlign='center';x.fillText('SCRAP GOLEM',480,260);x.fillStyle='#ffd966';x.font='bold 74px system-ui';x.fillText('LASER MAZE',480,340); drawGolem(480,550,1.2,Math.sin(t/20)*0.05,true); x.fillStyle='#d7e3ea';x.font='bold 32px system-ui';x.fillText('STICK: SHIFT LANES',480,760);x.fillText('BUTTON 1: FIRE / START',480,808);x.fillText('BUTTON 2: BULLDOZE DASH',480,856); x.fillStyle=t%60<30?'#fff':'#8ff';x.font='bold 38px system-ui';x.fillText('PRESS BUTTON 1',480,915); return} if(core){x.fillStyle='#5ef';x.beginPath();x.arc(480,120,70+Math.sin(t/8)*6,0,7);x.fill();x.fillStyle='#123';x.beginPath();x.arc(480,120,35,0,7);x.fill();x.fillStyle='#fff';x.font='bold 24px system-ui';x.textAlign='center';x.fillText('CORE',480,126)} for(let h of hazards){if(h.type==='beam'){if(h.warn>0){x.fillStyle=t%10<5?'rgba(255,80,80,0.18)':'rgba(255,180,180,0.1)';x.fillRect(h.x-24,h.y,48,h.h);x.strokeStyle='#f66';x.lineWidth=4;x.strokeRect(h.x-24,h.y,48,h.h)}else{x.fillStyle='rgba(255,60,60,0.75)';x.fillRect(h.x-18,h.y,36,h.h);x.fillStyle='rgba(255,220,220,0.65)';x.fillRect(h.x-6,h.y,12,h.h)}} else {x.fillStyle='#f84';x.beginPath();x.arc(h.x,h.y,h.r,0,7);x.fill()}} for(let e of enemies){x.save();x.translate(e.x,e.y); if(e.type==='turret'){x.fillStyle='#a85';x.fillRect(-26,-22,52,44);x.fillStyle='#fd6';x.fillRect(-8,10,16,26);x.fillStyle='#321';x.fillRect(-14,-8,28,12)}else{ x.fillStyle='#c44';x.fillRect(-22,-18,44,36);x.fillStyle='#822';x.fillRect(-14,18,10,16);x.fillRect(4,18,10,16)} x.restore()} for(let b of bullets){x.fillStyle='#9ff';x.beginPath();x.arc(b.x,b.y,b.r,0,7);x.fill()} for(let p of particles){x.globalAlpha=Math.max(0,p.a);x.fillStyle=p.c;x.beginPath();x.arc(p.x,p.y,p.r,0,7);x.fill();x.globalAlpha=1} if(state!=='dead'&&state!=='win')drawGolem(player.x,player.y,1,player.dir*0.12+Math.sin(t/8)*0.01,player.dash>0); if(flash>0){x.fillStyle='rgba(255,80,80,'+(flash/30)+')';x.fillRect(0,0,W,H)} x.textAlign='left';x.fillStyle='#d7e3ea';x.font='bold 28px system-ui';x.fillText('SCORE '+score,110,54);x.fillText('WAVE '+wave,360,54);x.fillText('BEST '+best,590,54); x.fillStyle='#f66';for(let i=0;i<player.hp;i++)x.fillRect(110+i*34,840,24,24); x.fillStyle='#8ff';x.fillRect(110,876,180*player.heat,12);x.strokeStyle='#355';x.strokeRect(110,876,180,12); if(combo>1&&comboTimer>0){x.fillStyle='#ffd966';x.font='bold 30px system-ui';x.fillText('COMBO x'+combo,740,876)} if(msgTimer>0&&state==='play'){x.textAlign='center';x.fillStyle='rgba(255,255,255,'+Math.min(1,msgTimer/60)+')';x.font='bold 38px system-ui';x.fillText(core?'BREAK THE CORE':('WAVE '+wave),480,150);msgTimer--} if(state==='dead'||state==='win'){x.fillStyle='rgba(0,0,0,0.55)';x.fillRect(90,220,780,360);x.textAlign='center';x.fillStyle=state==='win'?'#8ff':'#f88';x.font='bold 86px system-ui';x.fillText(state==='win'?'SYSTEM CRUSHED':'SCRAPED',480,340);x.fillStyle='#fff';x.font='bold 34px system-ui';x.fillText(state==='win'?'BONUS +500':'FINAL SCORE '+score,480,420);x.fillText('PRESS BUTTON 1 TO RETRY',480,500)}} function drawGolem(px,py,s,r,boost){x.save();x.translate(px,py);x.rotate(r);x.scale(s,s); if(boost){x.fillStyle='rgba(120,255,255,0.25)';x.beginPath();x.arc(0,0,48+Math.sin(t)*6,0,7);x.fill()} x.fillStyle='#8ba0a8';x.fillRect(-34,-30,68,56);x.fillStyle='#5f737b';x.fillRect(-22,-48,44,24);x.fillStyle='#cde';x.fillRect(-16,-42,10,10);x.fillRect(6,-42,10,10);x.fillStyle='#6d7f86';x.fillRect(-44,-16,18,18);x.fillRect(26,-16,18,18);x.fillRect(-26,26,16,22);x.fillRect(10,26,16,22);x.fillStyle='#ffd966';x.fillRect(-10,-6,20,10);x.restore()} function loop(){update();draw();requestAnimationFrame(loop)} loop();})();</script></body></html>",
